{
  "name": "payment-gateway-dashboard",
  "version": "1.0.0",
  "description": "Backend for payment gateway dashboard",
  "main": "src/app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "start:worker": "node src/worker.js",
    "dev": "nodemon src/app.js",
    "dev:worker": "nodemon src/worker.js",
    "debug": "nodemon --inspect src/app.js",
    "bootstrap:admin": "node src/scripts/bootstrapAdmin.js",
    "create-admin": "node src/scripts/createAdmin.js",
    "create-test-user": "node src/scripts/createTestUser.js",
    "check-db": "node src/scripts/checkDatabase.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "test": "node --test src/tests/*.test.js"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^6.14.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.6.3",
    "morgan": "^1.10.0",
    "mysql2": "^3.14.0",
    "sequelize": "^6.37.7",
    "uuid": "^8.3.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.0"
  }
}
