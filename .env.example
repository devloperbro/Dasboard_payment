# ============================================================
# .env.example — All required environment variables
# Copy to .env and fill values.
# NEVER commit real values. This file is safe to commit.
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=3000
API_PORT=3000

# ---- MySQL (Sequelize) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=buddypay
DB_USER=buddypay
DB_PASS=
MYSQL_ROOT_PASSWORD=
# Legacy var names (still read by sequelize.js as fallback)
DB_DATABASE=buddypay
DB_USERNAME=buddypay
DB_PASSWORD=

# ---- MongoDB ----
MONGO_URI=mongodb://localhost:27017/buddypay
# Legacy fallback
MONGODB_URI=mongodb://localhost:27017/buddypay

# ---- JWT ----
# REQUIRED in production. Must be a strong random secret (32+ chars)
JWT_SECRET=
# Variable name read by the code: JWT_EXPIRES_IN
JWT_EXPIRES_IN=24h

# ---- Redis — Cache (LRU, rate limiting, sessions) ----
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
REDIS_CACHE_PASSWORD=

# ---- Redis — Payment (Bull queues, AOF persistent, no eviction) ----
REDIS_PAYMENT_HOST=localhost
REDIS_PAYMENT_PORT=6380
REDIS_PAYMENT_PASSWORD=

# Legacy generic Redis vars (fallback used in queue.config.js and rateLimiter)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- CORS ----
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# ---- Logging ----
LOG_LEVEL=info

# ---- Main Admin Bootstrap ----
# Used by: node src/scripts/bootstrapAdmin.js   OR   npm run bootstrap:admin
# Set once, then remove from env (admin exists forever in DB)
ADMIN_EMAIL=admin@buddypay.com
ADMIN_USERNAME=admin
ADMIN_NAME=Main Administrator
ADMIN_PASSWORD=

# ---- Payment Providers (credentials from env ONLY — never stored in DB) ----
# Razorpay (not yet implemented — stubs return NOT_IMPLEMENTED)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# PhonePe (not yet implemented — stubs return NOT_IMPLEMENTED)
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1

# ---- UNPAY Gateway (legacy — DISABLED in production) ----
# Do not configure these in production. Payout path is blocked.
UNPAY_KEY_ID=
UNPAY_KEY_SECRET=
UNPAY_KEY=
UNPAY_IV=
UNPAY_CALLBACK_URL=

# ---- Frontend (Vite build) ----
VITE_API_URL=http://localhost:3000/api

